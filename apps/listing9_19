#include "embedDIP.hpp"
#include <Arduino.h>

#ifndef PIN_BUTTON
#define PIN_BUTTON 15
#endif

SET_LOOP_TASK_STACK_SIZE(16 * 1024 * 2);

embedDIP::SerialDev serial(&esp32_uart);

embedDIP::Image inImg;
embedDIP::Image gX;
embedDIP::Image gY;
embedDIP::Image outImg;

void setup() {
  serial.init();

  inImg = embedDIP::Image(IMAGE_RES_QVGA, IMAGE_FORMAT_GRAYSCALE);
  gX = embedDIP::Image(IMAGE_RES_QVGA, IMAGE_FORMAT_GRAYSCALE);
  gY = embedDIP::Image(IMAGE_RES_QVGA, IMAGE_FORMAT_GRAYSCALE);
  outImg = embedDIP::Image(IMAGE_RES_QVGA, IMAGE_FORMAT_GRAYSCALE);

  pinMode(PIN_BUTTON, INPUT_PULLUP);
}

void loop() {
  if (digitalRead(PIN_BUTTON) == LOW) {
    serial.capture(inImg);

    // Gaussian derivatives (sigma = 1.2)
    inImg.gaussianGradients(gX, gY, 1.2f);

    // Send gx, gy
    gX.convertTo();
    serial.send(gX);
    gY.convertTo();
    serial.send(gY);

    // Gradient magnitude
    outImg.gradientMagnitude(gX, gY);
    outImg.convertTo();
    serial.send(outImg);
  }
  delay(150);
}
