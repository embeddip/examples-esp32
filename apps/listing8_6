#include "embedDIP.hpp"
#include <Arduino.h>

#define PIN_BUTTON 15

SET_LOOP_TASK_STACK_SIZE(16 * 1024 * 2);

embedDIP::SerialDev serial(&esp32_uart);

embedDIP::Image inImg;
embedDIP::Image outImg;

embedDIP::Image boatMagnitude;
embedDIP::Image boatPhase;

embedDIP::Image mandrillMagnitude;
embedDIP::Image mandrillPhase;

void setup() {
  serial.init();

  inImg = embedDIP::Image(256, 256, IMAGE_FORMAT_GRAYSCALE);
  outImg = embedDIP::Image(256, 256, IMAGE_FORMAT_GRAYSCALE);

  boatMagnitude = embedDIP::Image(256, 256, IMAGE_FORMAT_GRAYSCALE);
  boatPhase = embedDIP::Image(256, 256, IMAGE_FORMAT_GRAYSCALE);

  mandrillMagnitude = embedDIP::Image(256, 256, IMAGE_FORMAT_GRAYSCALE);
  mandrillPhase = embedDIP::Image(256, 256, IMAGE_FORMAT_GRAYSCALE);

  pinMode(PIN_BUTTON, INPUT_PULLUP);
}

void loop() {
  if (digitalRead(PIN_BUTTON) == LOW) {
    serial.capture(inImg);
    inImg.fft(inImg);
    inImg._abs_(boatMagnitude);
    inImg._phase_(boatPhase);

    serial.capture(inImg);
    inImg.fft(inImg);
    inImg._abs_(mandrillMagnitude);
    inImg._phase_(mandrillPhase);

    outImg.polarToCart(boatMagnitude, mandrillPhase);
    outImg.ifft(outImg);
    outImg.convertTo();
    serial.send(outImg);

    outImg.polarToCart(mandrillMagnitude, boatPhase);
    outImg.ifft(outImg);
    outImg.convertTo();
    serial.send(outImg);
  }
  delay(150);
}
