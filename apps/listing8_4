#include "embedDIP.h"
#include <Arduino.h>

#define PIN_BUTTON 15

SET_LOOP_TASK_STACK_SIZE(16 * 1024 * 2);

serial_t *serial = &esp32_uart;

Image *inImg = nullptr;
Image *outImg = nullptr;

Image *mandrillMagnitude = nullptr;
Image *mandrillPhase = nullptr;

Image *boatMagnitude = nullptr;
Image *boatPhase = nullptr;

void setup() {
  serial->init();

  createImageWH(256, 256, IMAGE_FORMAT_GRAYSCALE, &inImg);
  createImageWH(256, 256, IMAGE_FORMAT_GRAYSCALE, &outImg);
  createImageWH(256, 256, IMAGE_FORMAT_GRAYSCALE, &mandrillMagnitude);
  createImageWH(256, 256, IMAGE_FORMAT_GRAYSCALE, &mandrillPhase);
  createImageWH(256, 256, IMAGE_FORMAT_GRAYSCALE, &boatMagnitude);
  createImageWH(256, 256, IMAGE_FORMAT_GRAYSCALE, &boatPhase);

  pinMode(PIN_BUTTON, INPUT_PULLUP);
}

void loop() {
  if (digitalRead(PIN_BUTTON) == LOW) {

    serial->capture(inImg);
    fft(inImg, inImg);
    _abs_(inImg, mandrillMagnitude);
    _phase_(inImg, mandrillPhase);

    serial->capture(inImg);
    fft(inImg, inImg);
    _abs_(inImg, boatMagnitude);
    _phase_(inImg, boatPhase);

    polarToCart(boatMagnitude, mandrillPhase, outImg);
    ifft(outImg, outImg);
    convertTo(outImg);
    serial->send(outImg);

    polarToCart(mandrillMagnitude, boatPhase, outImg);
    ifft(outImg, outImg);
    convertTo(outImg);
    serial->send(outImg);
  }
  delay(100);
}
