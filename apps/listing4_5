#include "embedDIP.hpp"

const int PIN_BUTTON = 15;

SET_LOOP_TASK_STACK_SIZE(16 * 1024 * 2);

embedDIP::SerialDev serial(&esp32_uart);

embedDIP::Image rgbImg;
embedDIP::Image grayImg;
embedDIP::Image yuvImg;

void setup() {
  serial.init();
  rgbImg = embedDIP::Image(IMAGE_RES_QVGA, IMAGE_FORMAT_RGB565);
  grayImg = embedDIP::Image(IMAGE_RES_QVGA, IMAGE_FORMAT_GRAYSCALE);
  yuvImg = embedDIP::Image(IMAGE_RES_QVGA, IMAGE_FORMAT_YUV);
  pinMode(PIN_BUTTON, INPUT_PULLUP);
}

void loop() {
  if (digitalRead(PIN_BUTTON) == LOW) {
    serial.capture(rgbImg);
    rgbImg.cvtColor(grayImg, CVT_RGB565_TO_GRAYSCALE);
    serial.send(grayImg);
    rgbImg.cvtColor(yuvImg, CVT_RGB565_TO_YUV);
    serial.send(yuvImg);
  }
  delay(100);
}